DISCORD_TOKEN=your_bot_token
CLIENT_ID=your_application_id
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/andbot

# Optional dev server ID (right-click server → Copy Server ID)
GUILD_ID=

# Slash command registration (pick one approach):
# - Default: global commands only (no duplicates; updates can take ~1 hour)
# - GUILD_COMMANDS_ONLY=true: instant commands in GUILD_ID only (good for local dev)
# - GUILD_INSTANT_COMMANDS=true: global + guild (instant in dev server, but duplicates there)
# GUILD_COMMANDS_ONLY=false
# GUILD_INSTANT_COMMANDS=false

# Economy tuning
CURRENCY_NAME=coins
STARTING_BALANCE=0
DAILY_AMOUNT=500
WEEKLY_AMOUNT=2500
MIN_BET=1
MAX_BET=100000
CHALLENGE_EXPIRY_MINUTES=5
BLACKJACK_SESSION_TIMEOUT_MINUTES=10

# Lottery
LOTTERY_TICKET_PRICE=100
LOTTERY_DRAW_INTERVAL_DAYS=7
LOTTERY_RAKE_PERCENT=5
LOTTERY_MAX_TICKETS_PER_PURCHASE=50

# Daily streak & activity rewards
DAILY_STREAK_BONUS_PER_DAY=10
DAILY_MAX_PAYOUT=10000
MESSAGE_REWARD_AMOUNT=1
MESSAGE_REWARD_COOLDOWN_MS=30000
# ACTIVITY_DEBUG=true
